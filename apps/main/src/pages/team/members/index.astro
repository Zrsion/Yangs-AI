---
import { getCollection } from "astro:content";
import SubpageLayout from "../../../layouts/SubpageLayout.astro";
import BackButton from "../../../components/BackButton.astro";

type StudentLevel = "undergraduate" | "master" | "phd";

const levelMeta: Array<{ key: StudentLevel; label: string }> = [
  { key: "phd", label: "PhD" },
  { key: "master", label: "Master" },
  { key: "undergraduate", label: "Undergraduate" },
];

const statusText = (graduated: boolean) => (graduated ? "Graduated Student" : "Current Student");

const escapeXml = (input: string) =>
  input
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/\"/g, "&quot;")
    .replace(/'/g, "&#39;");

const buildFallbackAvatar = (displayName: string, type: "employee" | "student") => {
  const hash = Array.from(displayName).reduce((acc, char) => acc * 31 + char.charCodeAt(0), 7);
  const unit = (offset: number) => {
    const x = Math.sin((hash + offset) * 12.9898) * 43758.5453;
    return x - Math.floor(x);
  };

  const palettes =
    type === "employee"
      ? [
          ["#345171", "#1a2533"],
          ["#3f5f52", "#1e2b25"],
          ["#4b446f", "#23203a"],
        ]
      : [
          ["#4f4c86", "#221f43"],
          ["#3e6a7a", "#1b2d38"],
          ["#6d5a3f", "#2f2619"],
        ];
  const skinTones = ["#f3d8bf", "#eac7a7", "#d9ac86", "#c89269", "#b67e57"];
  const hairColors = ["#1b1a1f", "#30261e", "#3c2f2a", "#2f3138", "#4a3a30"];

  const palette = palettes[Math.floor(unit(1) * palettes.length)];
  const skin = skinTones[Math.floor(unit(2) * skinTones.length)];
  const hair = hairColors[Math.floor(unit(3) * hairColors.length)];
  const shirtHue = Math.floor(190 + unit(4) * 110);
  const eyeOffset = 18 + Math.floor(unit(5) * 6);
  const mouthCurve = 8 + Math.floor(unit(6) * 6);
  const hairStyle = Math.floor(unit(7) * 3);

  const hairPath =
    hairStyle === 0
      ? "M 126 166 C 130 118, 164 92, 200 92 C 236 92, 270 118, 274 166 C 258 148, 236 138, 214 138 C 190 138, 168 148, 126 166 Z"
      : hairStyle === 1
      ? "M 126 166 C 122 120, 160 84, 200 84 C 244 84, 278 118, 274 166 C 254 142, 228 128, 196 128 C 172 128, 146 140, 126 166 Z"
      : "M 126 166 C 132 122, 162 98, 200 98 C 238 98, 268 122, 274 166 C 254 154, 236 150, 200 150 C 166 150, 146 154, 126 166 Z";

  const svg = `<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 400 400' role='img' aria-label='${escapeXml(displayName)}'>
  <defs>
    <linearGradient id='g' x1='0' y1='0' x2='1' y2='1'>
      <stop offset='0%' stop-color='${palette[0]}'/>
      <stop offset='100%' stop-color='${palette[1]}'/>
    </linearGradient>
    <radialGradient id='halo' cx='20%' cy='10%' r='76%'>
      <stop offset='0%' stop-color='rgba(247,251,255,0.34)'/>
      <stop offset='100%' stop-color='rgba(255,255,255,0)'/>
    </radialGradient>
  </defs>
  <rect width='400' height='400' fill='url(#g)'/>
  <rect width='400' height='400' fill='url(#halo)'/>
  <ellipse cx='200' cy='366' rx='130' ry='78' fill='hsl(${shirtHue}, 44%, 34%)' opacity='0.92'/>
  <circle cx='200' cy='190' r='74' fill='${skin}'/>
  <path d='${hairPath}' fill='${hair}'/>
  <circle cx='${200 - eyeOffset}' cy='190' r='5.2' fill='#1d1f24'/>
  <circle cx='${200 + eyeOffset}' cy='190' r='5.2' fill='#1d1f24'/>
  <path d='M 176 224 Q 200 ${224 + mouthCurve} 224 224' stroke='#694a38' stroke-width='3.2' fill='none' stroke-linecap='round'/>
</svg>`;

  return `data:image/svg+xml,${encodeURIComponent(svg)}`;
};

const getAvatarSources = (member: Member) => {
  const fallback = buildFallbackAvatar(member.name, member.memberType);
  return {
    src: member.avatar || fallback,
    fallback,
  };
};

const memberEntries = await getCollection("team-members");

type Member = {
  slug: string;
  order: number;
  graduated: boolean;
} & (typeof memberEntries)[number]["data"];

type EmployeeMember = Extract<Member, { memberType: "employee" }>;
type StudentMember = Extract<Member, { memberType: "student" }>;

const isEmployeeMember = (member: Member): member is EmployeeMember => member.memberType === "employee";
const isStudentMember = (member: Member): member is StudentMember => member.memberType === "student";

const members: Member[] = memberEntries
  .map((entry) => ({
    slug: entry.id.replace(/\.md$/, ""),
    ...entry.data,
    graduated: entry.data.memberType === "student" ? entry.data.graduated ?? false : false,
    order: entry.data.order ?? 999,
  }))
  .sort((a, b) => a.order - b.order || a.name.localeCompare(b.name));

const employees = members.filter(isEmployeeMember);

const buildStudentGroups = (graduated: boolean) =>
  levelMeta
    .map((level) => ({
      ...level,
      members: members.filter(isStudentMember).filter(
        (member) =>
          member.graduated === graduated &&
          member.studentLevel === level.key,
      ),
    }))
    .filter((group) => group.members.length > 0);

const currentStudentGroups = buildStudentGroups(false);
const alumniStudentGroups = buildStudentGroups(true);
---

<SubpageLayout title="Team | Members | Yangs AI" description="YangsAI team members and profiles.">
  <BackButton href="/team" label="Back to Team" />
  <p class="font-tech mt-5 text-xs uppercase tracking-[0.12em] text-zinc-300">Team</p>
  <h1 class="mt-2 text-4xl font-semibold tracking-tight text-zinc-100 md:text-5xl">Members</h1>

  {employees.length === 0 && currentStudentGroups.length === 0 && alumniStudentGroups.length === 0 ? (
    <section class="mt-8 rounded-xl border border-white/12 bg-white/5 p-6 text-zinc-300">
      No team members are published yet. Add markdown files under `src/content/team-members/`.
    </section>
  ) : null}

  {employees.length > 0 ? (
    <section class="mt-8">
      <p class="font-tech text-xs uppercase tracking-[0.12em] text-zinc-300">Employees</p>
      <div class="mt-3 grid gap-4 md:grid-cols-2">
        {employees.map((member) => (
          <a href={`/team/members/${member.slug}`} class="rounded-xl border border-white/15 bg-white/5 p-5 hover:bg-white/10">
            {(() => {
              const avatar = getAvatarSources(member);
              return (
            <div class="flex items-center gap-3">
              <img
                src={avatar.src}
                alt={`${member.name} portrait`}
                class="h-14 w-14 rounded-full border border-white/16 object-cover"
                loading="lazy"
                decoding="async"
                data-fallback-src={avatar.fallback}
              />
              <div>
                <h2 class="text-xl font-medium text-zinc-100">{member.name}</h2>
                <p class="mt-1 text-sm text-zinc-300">{member.role} · {member.affiliation}</p>
              </div>
            </div>
              );
            })()}
            <p class="mt-2 text-sm leading-relaxed text-zinc-300">{member.summary}</p>
            {member.updatedOn ? <p class="mt-3 text-xs text-zinc-400">Updated: {member.updatedOn}</p> : null}
          </a>
        ))}
      </div>
    </section>
  ) : null}

  {currentStudentGroups.length > 0 || alumniStudentGroups.length > 0 ? (
    <section class="mt-8">
      <p class="font-tech text-xs uppercase tracking-[0.12em] text-zinc-300">Students</p>

      {currentStudentGroups.length > 0 ? (
        <div class="mt-5 rounded-2xl border border-white/12 bg-white/4 p-4 md:p-5" data-student-section="current">
          <p class="font-tech text-[0.7rem] uppercase tracking-[0.12em] text-zinc-300">Current Students</p>
          {currentStudentGroups.map((group) => (
            <div class="mt-4 ml-1 rounded-xl border border-white/10 bg-white/4 p-3 md:ml-2" data-student-level-group>
              <p class="font-tech text-[0.62rem] uppercase tracking-[0.12em] text-zinc-400">Level · {group.label}</p>
              <div class="mt-2 grid gap-4 md:grid-cols-2">
                {group.members.map((member) => (
                  <a href={`/team/members/${member.slug}`} class="rounded-xl border border-white/15 bg-white/5 p-5 hover:bg-white/10">
                    {(() => {
                      const avatar = getAvatarSources(member);
                      return (
                    <div class="flex items-center gap-3">
                      <img
                        src={avatar.src}
                        alt={`${member.name} portrait`}
                        class="h-14 w-14 rounded-full border border-white/16 object-cover"
                        loading="lazy"
                        decoding="async"
                        data-fallback-src={avatar.fallback}
                      />
                      <div>
                        <h2 class="text-xl font-medium text-zinc-100">{member.name}</h2>
                        <p class="mt-1 text-sm text-zinc-300">{member.role} · {member.affiliation}</p>
                      </div>
                    </div>
                      );
                    })()}
                    <p class="mt-2 text-sm leading-relaxed text-zinc-300">{member.summary}</p>
                    <div class="mt-2 text-xs text-zinc-400">{statusText(member.graduated)}</div>
                    {member.updatedOn ? <p class="mt-3 text-xs text-zinc-400">Updated: {member.updatedOn}</p> : null}
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      ) : null}

      {alumniStudentGroups.length > 0 ? (
        <div class="mt-7 rounded-2xl border border-white/12 bg-white/4 p-4 md:p-5" data-student-section="graduated">
          <p class="font-tech text-[0.7rem] uppercase tracking-[0.12em] text-zinc-300">Graduated Students</p>
          {alumniStudentGroups.map((group) => (
            <div class="mt-4 ml-1 rounded-xl border border-white/10 bg-white/4 p-3 md:ml-2" data-student-level-group>
              <p class="font-tech text-[0.62rem] uppercase tracking-[0.12em] text-zinc-400">Level · {group.label}</p>
              <div class="mt-2 grid gap-4 md:grid-cols-2">
                {group.members.map((member) => (
                  <a href={`/team/members/${member.slug}`} class="rounded-xl border border-white/15 bg-white/5 p-5 hover:bg-white/10">
                    {(() => {
                      const avatar = getAvatarSources(member);
                      return (
                    <div class="flex items-center gap-3">
                      <img
                        src={avatar.src}
                        alt={`${member.name} portrait`}
                        class="h-14 w-14 rounded-full border border-white/16 object-cover"
                        loading="lazy"
                        decoding="async"
                        data-fallback-src={avatar.fallback}
                      />
                      <div>
                        <h2 class="text-xl font-medium text-zinc-100">{member.name}</h2>
                        <p class="mt-1 text-sm text-zinc-300">{member.role} · {member.affiliation}</p>
                      </div>
                    </div>
                      );
                    })()}
                    <p class="mt-2 text-sm leading-relaxed text-zinc-300">{member.summary}</p>
                    <div class="mt-2 flex flex-wrap items-center gap-2 text-xs">
                      <span class="text-zinc-400">{statusText(member.graduated)}</span>
                      {member.graduationYear ? <span class="text-zinc-400">Class of {member.graduationYear}</span> : null}
                    </div>
                    {member.updatedOn ? <p class="mt-3 text-xs text-zinc-400">Updated: {member.updatedOn}</p> : null}
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      ) : null}
    </section>
  ) : null}

  <script>
    document.querySelectorAll("img[data-fallback-src]").forEach((img) => {
      img.addEventListener("error", () => {
        const fallback = img.getAttribute("data-fallback-src");
        if (!fallback || img.getAttribute("src") === fallback) return;
        img.setAttribute("src", fallback);
      });
    });
  </script>
</SubpageLayout>
